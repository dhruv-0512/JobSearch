# LLM Provider Configuration
# Options: "ollama", "gemini", or "deepseek"
LLM_PROVIDER=deepseek

# Default model to use
# For DeepSeek: "deepseek-chat" (recommended) or "deepseek-reasoner"
# For Ollama: "gemma3:4b", "qwen3:4b", "mistral:7b", etc.
# For Gemini: "gemini-2.5-pro", "gemini-2.5-flash", etc.
DEFAULT_MODEL=deepseek-chat

# DeepSeek API Key (required if using DeepSeek provider)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# Optional: override DeepSeek base URL (default: https://api.deepseek.com)
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Google Gemini API Key (required if using Gemini provider)
GEMINI_API_KEY=your_gemini_api_key_here

# GitHub Personal Access Token (optional, raises rate limit from 60 to 5000/hr)
GITHUB_TOKEN=your_github_token_here

# FastAPI server port (default: 8000)
# PORT=8000
